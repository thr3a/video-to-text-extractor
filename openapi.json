{"openapi":"3.1.0","info":{"title":"Yomitoku FastAPI Server","description":"Yomitoku を HTTP API として提供するサーバー実装です。\n\n主に以下の機能を提供します:\n- 画像/PDF のアップロードと OCR・レイアウト解析 (POST /analyze)\n- 稼働確認用のヘルスチェック (GET /health)\n\nSwagger UI では各エンドポイントの入力/出力例やエラー応答を確認できます。","license":{"name":"MIT License","url":"https://opensource.org/licenses/MIT"},"version":"0.1.0"},"paths":{"/":{"get":{"tags":["情報"],"summary":"ルート","description":"API の案内を返します。動作確認用に利用できます。\n\nSwagger UI: `/docs` / ReDoc: `/redoc`","operationId":"root__get","responses":{"200":{"description":"案内メッセージ","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RootResponse"}}}}}}},"/health":{"get":{"tags":["情報"],"summary":"ヘルスチェック","description":"実ファイル `test.png` を用いて OCR が期待どおり動作するかを確認します。\n\nresults.figures[0].paragraphs[0].contents に『こんにちは』が含まれていれば ok、そうでなければ ng を返します。","operationId":"health_health_get","responses":{"200":{"description":"サーバーの状態","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}},"/analyze":{"post":{"tags":["解析"],"summary":"ドキュメント解析","description":"画像 (JPG/PNG など) または PDF を受け取り、OCR とレイアウト解析を実施します。\n\n- `json`: Yomitoku の生 JSON をページ単位で返します。\n- `markdown`: 各ページの Markdown を生成し、連結して返します。\n- `vertical`/`horizontal`: 指定方向のテキストのみを抽出し、連結して返します。\n\n注意: 本サーバーは GPU(CUDA) 前提です。CUDA が無い環境では起動に失敗します。\nContent-Type は `multipart/form-data` を利用してください。","operationId":"analyze_document_analyze_post","parameters":[{"name":"format","in":"query","required":false,"schema":{"enum":["json","markdown","vertical","horizontal"],"type":"string","description":"出力フォーマット。`json`/`markdown`/`vertical`/`horizontal` から選択","examples":{"json":{"summary":"生 JSON","value":"json"},"markdown":{"summary":"Markdown","value":"markdown"},"vertical":{"summary":"縦書き","value":"vertical"},"horizontal":{"summary":"横書き","value":"horizontal"}},"default":"json","title":"Format"},"description":"出力フォーマット。`json`/`markdown`/`vertical`/`horizontal` から選択"}],"requestBody":{"required":true,"content":{"multipart/form-data":{"schema":{"$ref":"#/components/schemas/Body_analyze_document_analyze_post"}}}},"responses":{"200":{"description":"解析結果","content":{"application/json":{"schema":{"oneOf":[{"$ref":"#/components/schemas/AnalyzeJsonResponse"},{"$ref":"#/components/schemas/AnalyzeMarkdownResponse"},{"$ref":"#/components/schemas/AnalyzeVerticalResponse"},{"$ref":"#/components/schemas/AnalyzeHorizontalResponse"}],"discriminator":{"propertyName":"format","mapping":{"json":"#/components/schemas/AnalyzeJsonResponse","markdown":"#/components/schemas/AnalyzeMarkdownResponse","vertical":"#/components/schemas/AnalyzeVerticalResponse","horizontal":"#/components/schemas/AnalyzeHorizontalResponse"}},"title":"Response Analyze Document Analyze Post"}}}},"400":{"description":"無効なファイル形式や読み込み失敗などの入力エラー","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"415":{"description":"未対応の Content-Type","content":{"application/json":{"example":{"detail":"Unsupported Media Type"}}}},"500":{"description":"サーバー内部エラー","content":{"application/json":{"example":{"detail":"Internal Server Error"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"AnalyzeHorizontalResponse":{"properties":{"format":{"type":"string","const":"horizontal","title":"Format","description":"返却するフォーマット種別 (常に horizontal)"},"content":{"type":"string","title":"Content","description":"横書きテキストを連結した文字列"}},"type":"object","required":["format","content"],"title":"AnalyzeHorizontalResponse","description":"`format` が `horizontal` のときのレスポンス。"},"AnalyzeJsonResponse":{"properties":{"format":{"type":"string","const":"json","title":"Format","description":"返却するフォーマット種別 (常に json)"},"content":{"items":{"$ref":"#/components/schemas/DocumentAnalyzerSchema"},"type":"array","title":"Content","description":"ページごとの解析結果 (構造化 JSON)"}},"type":"object","required":["format","content"],"title":"AnalyzeJsonResponse","description":"`format` が `json` のときのレスポンス。\n\n`content` はページごとの `DocumentAnalyzerSchema` の配列。"},"AnalyzeMarkdownResponse":{"properties":{"format":{"type":"string","const":"markdown","title":"Format","description":"返却するフォーマット種別 (常に markdown)"},"content":{"type":"string","title":"Content","description":"Markdown 文字列"}},"type":"object","required":["format","content"],"title":"AnalyzeMarkdownResponse","description":"`format` が `markdown` のときのレスポンス。"},"AnalyzeVerticalResponse":{"properties":{"format":{"type":"string","const":"vertical","title":"Format","description":"返却するフォーマット種別 (常に vertical)"},"content":{"type":"string","title":"Content","description":"縦書きテキストを連結した文字列"}},"type":"object","required":["format","content"],"title":"AnalyzeVerticalResponse","description":"`format` が `vertical` のときのレスポンス。"},"Body_analyze_document_analyze_post":{"properties":{"file":{"type":"string","format":"binary","title":"File","description":"入力ファイル。画像 (JPG/PNG など) または PDF に対応。最大サイズは運用環境の制限に依存します。"}},"type":"object","required":["file"],"title":"Body_analyze_document_analyze_post"},"DocumentAnalyzerSchema":{"properties":{"paragraphs":{"items":{"$ref":"#/components/schemas/ParagraphSchema"},"type":"array","title":"Paragraphs"},"tables":{"items":{"$ref":"#/components/schemas/TableStructureRecognizerSchema"},"type":"array","title":"Tables"},"words":{"items":{"$ref":"#/components/schemas/WordPrediction"},"type":"array","title":"Words"},"figures":{"items":{"$ref":"#/components/schemas/FigureSchema"},"type":"array","title":"Figures"}},"additionalProperties":false,"type":"object","required":["paragraphs","tables","words","figures"],"title":"DocumentAnalyzerSchema"},"ErrorResponse":{"properties":{"detail":{"type":"string","title":"Detail","description":"エラーの詳細メッセージ"}},"type":"object","required":["detail"],"title":"ErrorResponse","description":"エラーレスポンスの共通形式。","examples":[{"detail":"画像の読み込みに失敗しました。"}]},"FigureSchema":{"properties":{"box":{"items":{"type":"integer"},"type":"array","maxItems":4,"minItems":4,"title":"Box"},"order":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Order"},"paragraphs":{"items":{"$ref":"#/components/schemas/ParagraphSchema"},"type":"array","title":"Paragraphs"},"direction":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Direction"}},"additionalProperties":false,"type":"object","required":["box","order","paragraphs","direction"],"title":"FigureSchema"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HealthResponse":{"properties":{"status":{"type":"string","title":"Status","description":"サーバーの状態 (ok で正常)"}},"type":"object","required":["status"],"title":"HealthResponse","description":"ヘルスチェックのレスポンス。","examples":[{"status":"ok"}]},"ParagraphSchema":{"properties":{"box":{"items":{"type":"integer"},"type":"array","maxItems":4,"minItems":4,"title":"Box"},"contents":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Contents"},"direction":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Direction"},"order":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Order"},"role":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Role"}},"additionalProperties":false,"type":"object","required":["box","contents","direction","order","role"],"title":"ParagraphSchema"},"RootResponse":{"properties":{"message":{"type":"string","title":"Message","description":"簡単な案内メッセージ"}},"type":"object","required":["message"],"title":"RootResponse","description":"ルートエンドポイントのレスポンス。","examples":[{"message":"turai.work"},{"message":"ようこそ Yomitoku API へ"}]},"TableCellSchema":{"properties":{"col":{"type":"integer","title":"Col"},"row":{"type":"integer","title":"Row"},"col_span":{"type":"integer","title":"Col Span"},"row_span":{"type":"integer","title":"Row Span"},"box":{"items":{"type":"integer"},"type":"array","maxItems":4,"minItems":4,"title":"Box"},"contents":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Contents"}},"additionalProperties":false,"type":"object","required":["col","row","col_span","row_span","box","contents"],"title":"TableCellSchema"},"TableLineSchema":{"properties":{"box":{"items":{"type":"integer"},"type":"array","maxItems":4,"minItems":4,"title":"Box"},"score":{"type":"number","title":"Score"}},"additionalProperties":false,"type":"object","required":["box","score"],"title":"TableLineSchema"},"TableStructureRecognizerSchema":{"properties":{"box":{"items":{"type":"integer"},"type":"array","maxItems":4,"minItems":4,"title":"Box"},"n_row":{"type":"integer","title":"N Row"},"n_col":{"type":"integer","title":"N Col"},"rows":{"items":{"$ref":"#/components/schemas/TableLineSchema"},"type":"array","title":"Rows"},"cols":{"items":{"$ref":"#/components/schemas/TableLineSchema"},"type":"array","title":"Cols"},"cells":{"items":{"$ref":"#/components/schemas/TableCellSchema"},"type":"array","title":"Cells"},"spans":{"items":{"$ref":"#/components/schemas/TableLineSchema"},"type":"array","title":"Spans"},"order":{"type":"integer","title":"Order"}},"additionalProperties":false,"type":"object","required":["box","n_row","n_col","rows","cols","cells","spans","order"],"title":"TableStructureRecognizerSchema"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"},"WordPrediction":{"properties":{"points":{"items":{"items":{"type":"integer"},"type":"array","maxItems":2,"minItems":2},"type":"array","maxItems":4,"minItems":4,"title":"Points"},"content":{"type":"string","title":"Content"},"direction":{"type":"string","title":"Direction"},"rec_score":{"type":"number","title":"Rec Score"},"det_score":{"type":"number","title":"Det Score"}},"additionalProperties":false,"type":"object","required":["points","content","direction","rec_score","det_score"],"title":"WordPrediction"}}},"tags":[{"name":"情報","description":"サービスの基本情報や動作確認に利用するエンドポイント群です。"},{"name":"解析","description":"画像や PDF を対象に OCR・レイアウト解析を行うエンドポイント群です。"}]}